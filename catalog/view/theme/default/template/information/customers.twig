{{ header }}

<main>
<div class="customers-block">
  <div class="container container--default">
    <!-- Хлебные крошки -->
    <div class="breadcrumbs">
      <a href="/" class="breadcrumbs__item">{{ text_breadcrumb_home }}</a>
      <a href="#!" class="breadcrumbs__item">{{ text_breadcrumb_about }}</a>
      <span class="breadcrumbs__item">{{ text_breadcrumb_customers }}</span>
    </div>

    {# ==================== customers-block__top ==================== #}
    <div class="customers-block__top">
      <div class="title title--mid">{{ sc.hero.title }} <span class="color-prime">{{ sc.hero.title_highlight }}</span></div>
      <div class="text-button">
        <span class="text-button__text">{{ sc.hero.review_invite }}</span>
        <button class="button button--mid-sec button--blue js-call-popup-static" data-id="modal-wr">{{ sc.hero.review_btn }}</button>
      </div>
      <p class="simple-text simple-text--th simple-text--dark simple-text--medium js-cut-text" data-max-chars="140">
        {{ sc.hero.desc }}
      </p>
    </div>
  </div>

  {# ==================== customers-block__bg-blue ==================== #}
  <div class="customers-block__bg-blue bg-blue">
    <div class="container container--default">
      <div class="customers-block__list">

        {% for i, customer in customers %}
          {# Вставляем рейтинг-блок после 8-й карточки (только на 1-й странице) #}
          {% if rating_after >= 0 and i == rating_after %}
            {# ==================== rate-customers (топ-10) ==================== #}
            <div class="rate-customers">
              <div class="rate-customers__body">
                <div class="rate-customers__top">
                  <div class="rate-customers__title">
                    <div class="title title--mid title--dark">{{ sc.rating.title }} <span class="color-prime">{{ sc.rating.title_highlight }}</span></div>
                    {% if sc.rating.tooltip %}
                    <div class="simp-item simp-item--gray simp-item--btn js-tooltip" data-text="{{ sc.rating.tooltip }}" data-positon="top">
                      <div class="simp-item__icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <path d="M12 0C18.6274 0 24 5.37258 24 12C24 18.6274 18.6274 24 12 24C5.37258 24 0 18.6274 0 12C0 5.37258 5.37258 0 12 0ZM11.6689 15.6377C11.2275 15.6377 10.8635 15.7948 10.5771 16.1094C10.2909 16.4108 10.1475 16.8106 10.1475 17.3086C10.1475 17.8067 10.2908 18.2137 10.5771 18.5283C10.8635 18.8429 11.2275 19 11.6689 19C12.1222 19 12.492 18.8428 12.7783 18.5283C13.0647 18.2137 13.208 17.8067 13.208 17.3086C13.2079 16.8106 13.0646 16.4108 12.7783 16.1094C12.492 15.7949 12.1222 15.6377 11.6689 15.6377ZM12.1162 5C10.8396 5.00002 9.83717 5.39962 9.10938 6.19922C8.38156 6.98573 8.01193 8.09363 8 9.52246L10.4521 9.54199C10.4641 8.93917 10.583 8.49345 10.8096 8.20508C11.0363 7.91669 11.371 7.77246 11.8125 7.77246C12.2179 7.77253 12.5218 7.87091 12.7246 8.06738C12.9274 8.26396 13.0292 8.57192 13.0293 8.99121C13.0293 9.3189 12.9633 9.60097 12.832 9.83691C12.7127 10.0729 12.5581 10.2961 12.3672 10.5059C12.1883 10.7156 11.9911 10.9315 11.7764 11.1543C11.5617 11.364 11.3588 11.6066 11.168 11.8818C10.989 12.144 10.84 12.4591 10.7207 12.8262C10.6014 13.1932 10.541 13.626 10.541 14.124H12.9219C12.9219 13.7309 12.9936 13.3899 13.1367 13.1016C13.2799 12.8001 13.4704 12.5244 13.709 12.2754C13.9476 12.0263 14.1985 11.7774 14.4609 11.5283C14.7234 11.2793 14.9676 11.0165 15.1943 10.7412C15.4329 10.4529 15.6244 10.1257 15.7676 9.75879C15.9226 9.37874 16 8.93937 16 8.44141C16 7.70736 15.8387 7.08447 15.5166 6.57324C15.2064 6.0621 14.7593 5.67526 14.1748 5.41309C13.6021 5.1378 12.9156 5 12.1162 5Z"/>
                        </svg>
                      </div>
                    </div>
                    {% endif %}
                  </div>
                  <a href="{{ sc.rating.btn_href }}" class="button button--mid button--blue">{{ sc.rating.btn_text }}</a>
                  <p class="simple-text simple-text--th simple-text--dark simple-text--medium js-cut-text" data-max-chars="140">
                    {{ sc.rating.desc }}
                  </p>
                </div>
                <div class="rate-customers__list js-rate-block">
                  {% for rc in top_customers %}
                  <div class="rate-item js-rate-item" data-count="{{ rc.active_objects }}">
                    <div class="rate-item__left">
                      <div class="rate-item__name">
                        <span>{{ loop.index }}</span>
                        <span>{{ rc.name }}</span>
                      </div>
                      <div class="rate-item__progressbar">
                        <span class="js-rate-item-line" style="width: {{ (rc.active_objects / max_objects * 100)|round }}%"></span>
                      </div>
                      <div class="simp-item simp-item--sec simp-item--purp-sec js-watch-fit-item">
                        <div class="simp-item__icon">
                          <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
                            <path d="M2.25913 8.23586L2.25013 8.25011H3.75013V15.0001C3.75013 15.199 3.82915 15.3898 3.9698 15.5304C4.11045 15.6711 4.30122 15.7501 4.50013 15.7501H13.5001C13.699 15.7501 13.8898 15.6711 14.0305 15.5304C14.1711 15.3898 14.2501 15.199 14.2501 15.0001V8.25011H15.7501C15.9111 8.25015 16.0678 8.19839 16.1971 8.10249C16.3264 8.00658 16.4214 7.87163 16.4681 7.71756C16.5148 7.5635 16.5106 7.39851 16.4563 7.24698C16.402 7.09545 16.3003 6.96542 16.1664 6.87611L9.41638 2.37611C9.29313 2.29388 9.14829 2.25 9.00013 2.25C8.85197 2.25 8.70713 2.29388 8.58388 2.37611L1.83388 6.87611C1.75192 6.93077 1.68154 7.00103 1.62674 7.08289C1.57195 7.16475 1.53382 7.2566 1.51452 7.3532C1.49523 7.4498 1.49516 7.54926 1.51431 7.64588C1.53346 7.74251 1.57145 7.83442 1.62613 7.91636C1.69613 8.01868 1.79088 8.10163 1.90155 8.15749C2.01223 8.21335 2.13524 8.24031 2.25913 8.23586ZM7.50013 10.5001C7.50013 10.3012 7.57915 10.1104 7.7198 9.96978C7.86045 9.82913 8.05122 9.75011 8.25013 9.75011H9.75013C9.94904 9.75011 10.1398 9.82913 10.2805 9.96978C10.4211 10.1104 10.5001 10.3012 10.5001 10.5001V14.2501H7.50013V10.5001Z"/>
                          </svg>
                        </div>
                        <div class="simp-item__text">{{ rc.active_objects }}</div>
                      </div>
                    </div>
                    <div class="rate-item__text">{{ rc.active_objects }} {{ text_objects }}</div>
                  </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          {% endif %}

          {# Карточка клиента #}
          <div class="customer-card">
            <div class="customer-card__body">
              <div class="customer-card__left">
                <picture class="customer-card__img">
                  <img class="lazy" src="image/images/empty.gif" data-src="image/{{ customer.logo }}" width="170" height="152" alt="{{ customer.name }}">
                </picture>
                <div class="customer-card__text-item">
                  <span class="customer-card__m-title">{{ text_activity }}</span>
                  <span class="customer-card__s-title">{{ customer.activity }}</span>
                </div>
                <div class="customer-card__text-item">
                  <span class="customer-card__m-title">{{ text_category }}</span>
                  <span class="customer-card__s-title">{{ customer.category }}</span>
                </div>
                {% if customer.website %}
                <a href="https://{{ customer.website }}" class="simp-item simp-item--five simp-item--btn simp-item--purp-sec" target="_blank">
                  <div class="simp-item__icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M7.5 12.75C7.725 18.15 9.9 21.75 12 21.75C14.1 21.75 16.275 18.15 16.5 12.75H7.5Z"/>
                      <path d="M12 2.25C9.9 2.25 7.725 5.85 7.5 11.25H16.5C16.275 5.85 14.1 2.25 12 2.25Z"/>
                      <path d="M18 11.25H22.5C22.125 6.675 18.9 2.925 14.625 1.875C16.5 3.525 17.85 7.05 18 11.25Z"/>
                      <path d="M6 12.75H1.5C1.8 17.325 5.025 21.075 9.375 22.125C7.5 20.475 6.15 16.95 6 12.75Z"/>
                      <path d="M18 12.75C17.85 16.95 16.5 20.475 14.625 22.125C18.9 21 22.125 17.25 22.5 12.75H18Z"/>
                      <path d="M5.99922 11.25C6.14922 7.05 7.49922 3.525 9.37422 1.875C5.09922 2.925 1.87422 6.675 1.57422 11.25H5.99922Z"/>
                    </svg>
                  </div>
                  <div class="simp-item__text">{{ customer.website }}</div>
                </a>
                {% endif %}
              </div>
              <div class="customer-card__right">
                <span class="customer-card__m-title">{{ text_review }}</span>
                <div class="customer-card__text">{{ customer.review }}</div>
              </div>
            </div>
          </div>
        {% endfor %}

        {# Рейтинг-блок если карточек меньше 8 на первой странице #}
        {% if rating_after >= 0 and customers|length <= rating_after %}
          {% include 'information/customers_rating.twig' ignore missing %}
        {% endif %}

      </div>

      {# Пагинация #}
      {% if pagination.total_pages > 1 %}
      <div class="customers-block__pagination">
        <nav class="catalog-pagination" aria-label="Catalog pagination">
          <a class="catalog-pagination__item catalog-pagination__item--control" href="{{ pagination.first }}" aria-label="First page">
            <span class="catalog-pagination__control">
              <span class="catalog-pagination__bar" aria-hidden="true"></span>
              <svg class="catalog-pagination__icon" width="8" height="12" viewBox="0 0 8 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6.5 1L2 6L6.5 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
          <a class="catalog-pagination__item catalog-pagination__item--control" href="{{ pagination.prev ? pagination.prev : pagination.first }}" aria-label="Previous page">
            <span class="catalog-pagination__control">
              <svg class="catalog-pagination__icon" width="8" height="12" viewBox="0 0 8 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6.5 1L2 6L6.5 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
          {% for page_item in pagination.pages %}
          <a class="catalog-pagination__item{% if page_item.active %} is-active{% endif %}" href="{{ page_item.href }}" aria-label="Page {{ page_item.number }}"{% if page_item.active %} aria-current="page"{% endif %}>
            <span class="catalog-pagination__text">{{ page_item.number }}</span>
          </a>
          {% endfor %}
          <a class="catalog-pagination__item catalog-pagination__item--control" href="{{ pagination.next ? pagination.next : pagination.last }}" aria-label="Next page">
            <span class="catalog-pagination__control">
              <svg class="catalog-pagination__icon" width="8" height="12" viewBox="0 0 8 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M1.5 1L6 6L1.5 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
          <a class="catalog-pagination__item catalog-pagination__item--control" href="{{ pagination.last }}" aria-label="Last page">
            <span class="catalog-pagination__control">
              <svg class="catalog-pagination__icon" width="8" height="12" viewBox="0 0 8 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M1.5 1L6 6L1.5 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="catalog-pagination__bar" aria-hidden="true"></span>
            </span>
          </a>
        </nav>
      </div>
      {% endif %}

    </div>
  </div>
</div>

{# ==================== section-ads (common) ==================== #}
<section class="section-ads">
  <div class="section-ads__body-wrap">
    <div class="container container--default">
      <div class="section-ads__body">
        <h1 class="h1-ads">{{ scom.ads.title }}</h1>
        <a href="{{ scom.ads.button_url }}" class="btn btn-book btn-ads">{{ scom.ads.button_text }}</a>
      </div>
    </div>
  </div>
</section>

{# ==================== agency (common) ==================== #}
<section class="agency">
  <div class="company-achivements-body">
    <div class="container container-company-achivements-body bg-realtor right bottom">
      <div class="container-achivements-left">
        <img src="image/{{ scom.agency.image }}" alt="logo" />
      </div>
      <div class="container-achivements-right">
        <h5>{{ scom.agency.title }}</h5>
        <div class="container-achivements-header-p" data-max-chars="360">
          {{ scom.agency.text|raw }}
        </div>
      </div>
    </div>
  </div>
</section>

</main>

{{ footer }}
